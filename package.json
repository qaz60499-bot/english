{
  "name": "yingyu-xingqiu",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 5180 --strictPort",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 127.0.0.1",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b --pretty false",
    "content:generate": "node scripts/generate-content.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "report:content": "node scripts/content-report.mjs",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "vite-plugin-pwa": "^0.21.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
